{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "preserveSymlinks": true,
    "rootDir": "src",
    "types": ["jest", "node"],
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["node_modules/@hexabot-ai/api/dist/*"]
    }
  },
  "include": ["src/**/*"]
}
